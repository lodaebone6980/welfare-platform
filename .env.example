# ============================================================
# 복사해서 .env.local 로 저장 후 값 채우기
# 서비스: govmate.co.kr (브랜드: 국민자료실)
# ============================================================

# 사이트 기본 — Vercel Env에 그대로 반영
NEXT_PUBLIC_SITE_URL=https://govmate.co.kr
NEXT_PUBLIC_SITE_NAME=국민자료실
NEXT_PUBLIC_SITE_DESC=2026년 최신 정부 지원금·복지·보조금·환급금 정보를 한눈에. 나에게 맞는 정책을 추천해드립니다.

# 분석 / 광고
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
NEXT_PUBLIC_GTM_ID=
NEXT_PUBLIC_ADSENSE_CLIENT=ca-pub-XXXXXXXXXXXXXXXX
NEXT_PUBLIC_NAVER_WCS=
NEXT_PUBLIC_META_PIXEL=
NEXT_PUBLIC_KAKAO_PIXEL=

# 내부 트래커 토글 ("0" 이면 비활성화)
NEXT_PUBLIC_INTERNAL_TRACKER=1

# 검색엔진 사이트 소유 확인 값 (콘솔 각각에서 발급)
GOOGLE_SITE_VERIFICATION=
NAVER_SITE_VERIFICATION=
BING_SITE_VERIFICATION=

# DB
DATABASE_URL=postgresql://user:password@host:5432/dbname

# AI
OPENAI_API_KEY=sk-...

# 이미지 저장 (Cloudflare R2)
CF_ACCOUNT_ID=
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_BUCKET=welfare-images
R2_PUBLIC_URL=https://images.yourdomain.com

# SNS
THREADS_USER_ID=
THREADS_ACCESS_TOKEN=

# 구글 광고
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_DEV_TOKEN=
GOOGLE_ADS_CUSTOMER_ID=
GOOGLE_ADS_REFRESH_TOKEN=

# 인증
NEXTAUTH_SECRET=랜덤문자열32자이상
NEXTAUTH_URL=https://govmate.co.kr
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=

# 공공데이터포털 (data.go.kr에서 발급) — URL-encoded 또는 raw 둘 다 가능
DATA_GO_KR_KEY=

# IndexNow (Bing Webmaster에서 발급) — 발급키는 /public/{KEY}.txt 로도 배포
INDEXNOW_KEY=
INDEXNOW_KEY_LOCATION=

# FCM (Firebase Console에서 발급)
FCM_SERVER_KEY=

# AdSense (승인 후 입력) — 위 NEXT_PUBLIC_ADSENSE_CLIENT와 동일 값 사용
ADSENSE_PUB_ID=ca-pub-XXXXXXXXXXXXXXXX
