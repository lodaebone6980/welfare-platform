{
  "manifest_version": 3,
  "name": "GovMate Indexer",
  "version": "0.1.0",
  "description": "지원금길잡이 색인 자동화 - 네이버 검색어드바이저 / 다음 페이지등록을 자동으로 요청합니다.",
  "permissions": ["storage", "alarms", "scripting", "tabs", "notifications"],
  "host_permissions": [
    "https://www.govmate.co.kr/*",
    "https://govmate.co.kr/*",
    "http://localhost:3000/*",
    "https://searchadvisor.naver.com/*",
    "https://register.search.daum.net/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "GovMate Indexer",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_page": "options.html",
  "content_scripts": [
    {
      "matches": ["https://searchadvisor.naver.com/console/board*"],
      "js": ["content-naver.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://register.search.daum.net/index.daum*"],
      "js": ["content-daum.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
