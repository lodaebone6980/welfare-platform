generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Policy {
  id                Int          @id @default(autoincrement())
  slug              String       @unique
  title             String
  content           String       @db.Text
  excerpt           String?
  description       String?      @db.Text
  eligibility       String?      @db.Text
  applicationMethod String?      @db.Text
  requiredDocuments String?      @db.Text
  deadline          String?
  focusKeyword      String?
  metaDesc          String?
  status            PolicyStatus @default(DRAFT)
  categoryId        Int?
  category          Category?    @relation(fields: [categoryId], references: [id])
  geoRegion         String?
  geoDistrict       String?
  featuredImg       String?
  thumbnail         String?
  applyUrl          String?
  externalId        String?      @unique
  externalUrl       String?
  viewCount         Int          @default(0)
  featured          Boolean      @default(false)
  featuredOrder     Int          @default(0)
  views             Int          @default(0)
  wpId              Int?         @unique
  priority          Float?
  publishedAt       DateTime?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  tags              String?
  faqs              Faq[]
  threadsPosts      ThreadsPost[]
  socialPosts       SocialPost[]

  @@index([status, publishedAt])
  @@index([geoRegion])
  @@index([status, categoryId])
  @@index([externalId])
}

model ThreadsPost {
  id        Int      @id @default(autoincrement())
  content   String   @db.Text
  format    String   @default("text")
  threadsId String?  @unique
  views     Int      @default(0)
  likes     Int      @default(0)
  comments  Int      @default(0)
  shares    Int      @default(0)
  verdict   String?
  status    String   @default("draft")
  policyId  Int?
  policy    Policy?  @relation(fields: [policyId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Category {
  id           Int      @id @default(autoincrement())
  name         String   @unique
  slug         String   @unique
  icon         String?
  displayOrder Int      @default(0)
  policies     Policy[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @default(now()) @updatedAt
}

model Faq {
  id       Int     @id @default(autoincrement())
  question String
  answer   String  @db.Text
  policyId Int?
  policy   Policy? @relation(fields: [policyId], references: [id])
  order    Int     @default(0)
}

model ApiSource {
  id           Int      @id @default(autoincrement())
  name         String   @unique
  url          String
  type         String   @default("REST")
  status       String   @default("active")
  lastSuccess  DateTime?
  lastError    DateTime?
  todayCount   Int      @default(0)
  totalCount   Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model UrlMapping {
  id      Int    @id @default(autoincrement())
  wpId    Int    @unique
  oldSlug String
  newSlug String @unique
}

model SocialPost {
  id          Int       @id @default(autoincrement())
  platform    String
  content     String    @db.Text
  imageUrl    String?
  scheduledAt DateTime?
  publishedAt DateTime?
  status      String    @default("draft")
  reach       Int       @default(0)
  likes       Int       @default(0)
  comments    Int       @default(0)
  policyId    Int?
  policy      Policy?   @relation(fields: [policyId], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model FcmToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  platform  String   @default("web")
  userId    String?
  createdAt DateTime @default(now())
}

// 유입/트래픽 추적 — 어드민 "유입 분석" 페이지의 데이터 소스
model PageView {
  id         BigInt   @id @default(autoincrement())
  path       String                             // /welfare/<slug> 등 경로 (쿼리 제거)
  fullPath   String?                            // 쿼리 포함 전체 경로
  title      String?                            // document.title
  referrer   String?                            // 원문 referrer URL
  source     String                             // direct/google/naver/bing/daum/facebook/threads/x/instagram/kakao/other
  medium     String?                            // organic/social/referral/direct 등
  device     String                             // mobile/tablet/desktop
  platform   String                             // web/app/app_ios/app_android (?src 또는 UA)
  os         String?                            // iOS/Android/Windows/macOS/Linux/Other
  browser    String?                            // Chrome/Safari/Firefox/Edge/Samsung/Naver 등
  country    String?                            // 국가 코드 (optional, Vercel geo)
  region     String?                            // 광역 (optional)
  sessionId  String                             // 쿠키 기반 30분 롤링 세션
  visitorId  String?                            // 쿠키 기반 방문자 식별자 (UV 계산)
  userAgent  String?
  utmSource  String?
  utmMedium  String?
  utmCampaign String?
  utmTerm    String?
  utmContent String?
  createdAt  DateTime @default(now())

  @@index([createdAt])
  @@index([path, createdAt])
  @@index([source, createdAt])
  @@index([device, createdAt])
  @@index([platform, createdAt])
  @@index([sessionId])
  @@index([visitorId])
}

enum PolicyStatus {
  DRAFT
  REVIEW
  PUBLISHED
  ARCHIVED
}
