generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Policy {
  id                Int          @id @default(autoincrement())
  slug              String       @unique
  title             String
  content           String       @db.Text
  excerpt           String?
  description       String?      @db.Text
  eligibility       String?      @db.Text
  applicationMethod String?      @db.Text
  requiredDocuments String?      @db.Text
  deadline          String?
  focusKeyword      String?
  metaDesc          String?
  status            PolicyStatus @default(DRAFT)
  categoryId        Int?
  category          Category?    @relation(fields: [categoryId], references: [id])
  geoRegion         String?
  geoDistrict       String?
  featuredImg       String?
  thumbnail         String?
  applyUrl          String?
  externalId        String?      @unique
  externalUrl       String?
  viewCount         Int          @default(0)
  featured          Boolean      @default(false)
  featuredOrder     Int          @default(0)
  views             Int          @default(0)
  wpId              Int?         @unique
  priority          Float?
  publishedAt       DateTime?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  tags              String?
  faqs              Faq[]
  threadsPosts      ThreadsPost[]
  socialPosts       SocialPost[]

  @@index([status, publishedAt])
  @@index([geoRegion])
  @@index([status, categoryId])
  @@index([externalId])
}

model ThreadsPost {
  id        Int      @id @default(autoincrement())
  content   String   @db.Text
  format    String   @default("text")
  threadsId String?  @unique
  views     Int      @default(0)
  likes     Int      @default(0)
  comments  Int      @default(0)
  shares    Int      @default(0)
  verdict   String?
  status    String   @default("draft")
  policyId  Int?
  policy    Policy?  @relation(fields: [policyId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Category {
  id           Int      @id @default(autoincrement())
  name         String   @unique
  slug         String   @unique
  icon         String?
  displayOrder Int      @default(0)
  policies     Policy[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @default(now()) @updatedAt
}

model Faq {
  id       Int     @id @default(autoincrement())
  question String
  answer   String  @db.Text
  policyId Int?
  policy   Policy? @relation(fields: [policyId], references: [id])
  order    Int     @default(0)
}

model ApiSource {
  id           Int      @id @default(autoincrement())
  name         String   @unique
  url          String
  type         String   @default("REST")
  status       String   @default("active")
  lastSuccess  DateTime?
  lastError    DateTime?
  todayCount   Int      @default(0)
  totalCount   Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model UrlMapping {
  id      Int    @id @default(autoincrement())
  wpId    Int    @unique
  oldSlug String
  newSlug String @unique
}

model SocialPost {
  id          Int       @id @default(autoincrement())
  platform    String
  content     String    @db.Text
  imageUrl    String?
  scheduledAt DateTime?
  publishedAt DateTime?
  status      String    @default("draft")
  reach       Int       @default(0)
  likes       Int       @default(0)
  comments    Int       @default(0)
  policyId    Int?
  policy      Policy?   @relation(fields: [policyId], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model FcmToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  platform  String   @default("web")
  userId    String?
  createdAt DateTime @default(now())
}

enum PolicyStatus {
  DRAFT
  REVIEW
  PUBLISHED
  ARCHIVED
}

// ──────────────────────────────────────────────────────
// NextAuth (Kakao + Admin Credentials) Auth models
// PrismaAdapter 가 사용하는 4개 모델 + role/passwordHash 확장
// ──────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String?   @unique
  name          String?
  image         String?
  emailVerified DateTime?
  role          String    @default("USER")
  passwordHash  String?
  accounts      Account[]
  sessions      Session[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([role])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
