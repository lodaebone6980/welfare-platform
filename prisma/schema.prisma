generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Policy {
  id                Int          @id @default(autoincrement())
  slug              String       @unique
  title             String
  content           String       @db.Text
  excerpt           String?
  description       String?      @db.Text
  eligibility       String?      @db.Text
  applicationMethod String?      @db.Text
  requiredDocuments String?      @db.Text
  deadline          String?
  focusKeyword      String?
  metaDesc          String?
  status            PolicyStatus @default(DRAFT)
  categoryId        Int?
  category          Category?    @relation(fields: [categoryId], references: [id])
  geoRegion         String?
  geoDistrict       String?
  featuredImg       String?
  thumbnail         String?
  applyUrl          String?
  externalId        String?      @unique
  externalUrl       String?
  viewCount         Int          @default(0)
  externalScore     Int          @default(0)
  externalSyncedAt  DateTime?
  featured          Boolean      @default(false)
  featuredOrder     Int          @default(0)
  views             Int          @default(0)
  wpId              Int?         @unique
  priority          Float?
  publishedAt       DateTime?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  tags              String?

  // ─── Canonical linking (2026-04) ──────────────
  canonicalId       Int?
  canonical         Policy?       @relation("PolicyCanonical", fields: [canonicalId], references: [id], onDelete: SetNull)
  derivatives       Policy[]      @relation("PolicyCanonical")

  faqs              Faq[]
  threadsPosts      ThreadsPost[]
  socialPosts       SocialPost[]

  @@index([status, publishedAt])
  @@index([geoRegion])
  @@index([status, categoryId])
  @@index([externalId])

  // Admin list / category filter performance (added by optimization)
  @@index([createdAt(sort: Desc)])
  @@index([status, createdAt(sort: Desc)])
  @@index([categoryId, createdAt(sort: Desc)])
  @@index([geoRegion, createdAt(sort: Desc)])
  @@index([canonicalId])
}

model ThreadsPost {
  id        Int      @id @default(autoincrement())
  content   String   @db.Text
  format    String   @default("text")
  threadsId String?  @unique
  views     Int      @default(0)
  likes     Int      @default(0)
  comments  Int      @default(0)
  shares    Int      @default(0)
  verdict   String?
  status    String   @default("draft")
  policyId  Int?
  policy    Policy?  @relation(fields: [policyId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Category {
  id           Int      @id @default(autoincrement())
  name         String   @unique
  slug         String   @unique
  icon         String?
  displayOrder Int      @default(0)
  policies     Policy[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @default(now()) @updatedAt
}

model Faq {
  id       Int     @id @default(autoincrement())
  question String
  answer   String  @db.Text
  policyId Int?
  policy   Policy? @relation(fields: [policyId], references: [id])
  order    Int     @default(0)
}

model ApiSource {
  id           Int      @id @default(autoincrement())
  name         String   @unique
  url          String
  type         String   @default("REST")
  status       String   @default("active")
  lastSuccess  DateTime?
  lastError    DateTime?
  todayCount   Int      @default(0)
  totalCount   Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  runs         CollectionRun[]
}

model UrlMapping {
  id      Int    @id @default(autoincrement())
  wpId    Int    @unique
  oldSlug String
  newSlug String @unique
}

model SocialPost {
  id          Int       @id @default(autoincrement())
  platform    String
  content     String    @db.Text
  imageUrl    String?
  scheduledAt DateTime?
  publishedAt DateTime?
  status      String    @default("draft")
  reach       Int       @default(0)
  likes       Int       @default(0)
  comments    Int       @default(0)
  policyId    Int?
  policy      Policy?   @relation(fields: [policyId], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model FcmToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  platform  String   @default("web")
  userId    String?
  createdAt DateTime @default(now())
}

// 유입/트래픽 추적 — 어드민 "유입 분석" 페이지의 데이터 소스
model PageView {
  id         BigInt   @id @default(autoincrement())
  path       String                             // /welfare/<slug> 등 경로 (쿼리 제거)
  fullPath   String?                            // 쿼리 포함 전체 경로
  title      String?                            // document.title
  referrer   String?                            // 원문 referrer URL
  source     String                             // direct/google/naver/bing/daum/facebook/threads/x/instagram/kakao/other
  medium     String?                            // organic/social/referral/direct 등
  device     String                             // mobile/tablet/desktop
  platform   String                             // web/app/app_ios/app_android (?src 또는 UA)
  os         String?                            // iOS/Android/Windows/macOS/Linux/Other
  browser    String?                            // Chrome/Safari/Firefox/Edge/Samsung/Naver 등
  country    String?                            // 국가 코드 (optional, Vercel geo)
  region     String?                            // 광역 (optional)
  sessionId  String                             // 쿠키 기반 30분 롤링 세션
  visitorId  String?                            // 쿠키 기반 방문자 식별자 (UV 계산)
  userAgent  String?
  utmSource  String?
  utmMedium  String?
  utmCampaign String?
  utmTerm    String?
  utmContent String?
  createdAt  DateTime @default(now())

  @@index([createdAt])
  @@index([path, createdAt])
  @@index([source, createdAt])
  @@index([device, createdAt])
  @@index([platform, createdAt])
  @@index([sessionId])
  @@index([visitorId])
  // 유료/오가닉 분류 + 캠페인 분석용 (2026-04 추가)
  @@index([utmMedium, createdAt])
  @@index([utmCampaign, createdAt])
  @@index([source, utmMedium, createdAt])
}

enum PolicyStatus {
  DRAFT
  REVIEW
  PUBLISHED
  ARCHIVED
}

// ──────────────────────────────────────────────────────
// NextAuth (Kakao + Admin Credentials) Auth models
// PrismaAdapter 가 사용하는 4개 모델 + role/passwordHash 확장
// ──────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String?   @unique
  name          String?
  image         String?
  emailVerified DateTime?
  role          String    @default("USER")  // USER | ADMIN | BLOCKED
  passwordHash  String?
  // 2026-04 추가: 회원관리 확장
  lastLoginAt   DateTime?                    // 마지막 로그인 (NextAuth signIn 콜백에서 갱신)
  blockedAt     DateTime?                    // 차단 처리 시각 (role = BLOCKED 일 때만 의미 있음)
  blockedReason String?                      // 차단 사유 (관리 메모)
  accounts      Account[]
  sessions      Session[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([role])
  @@index([createdAt(sort: Desc)])
  @@index([lastLoginAt])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model CollectionRun {
  id          Int       @id @default(autoincrement())
  sourceId    Int
  source      ApiSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  startedAt   DateTime  @default(now())
  finishedAt  DateTime?
  status      String    @default("running") // running | success | error | partial
  fetched     Int       @default(0)
  created     Int       @default(0)
  updated     Int       @default(0)
  skipped     Int       @default(0)
  errorMsg    String?   @db.Text
  durationMs  Int?
  triggeredBy String    @default("manual")

  @@index([sourceId, startedAt(sort: Desc)])
  @@index([startedAt(sort: Desc)])
}

// ───────────────────────────────────────────────────────────────
// 알림 설정 (회원별 푸시 수신 선호)
// - userId 에 대해 1:1, 비로그인 유저는 row 없음 (기본값 사용)
// - quietStart / quietEnd 는 HH:MM 형식 문자열
// - categorySlugs 가 빈 배열이면 전체 카테고리 구독으로 간주
// ───────────────────────────────────────────────────────────────
model NotificationPref {
  id             String   @id @default(cuid())
  userId         String   @unique
  enabled        Boolean  @default(true)
  dailyDigest    Boolean  @default(true)
  categorySlugs  String[] @default([])
  regionCodes    String[] @default([])
  quietStart     String   @default("22:00")
  quietEnd       String   @default("08:00")
  locale         String   @default("ko-KR")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([enabled])
}

// ─────────────────────────────────────────────────────────────
// 사이트 페이지 (약관, 개인정보처리방침, 소개, 문의 등)
//  - slug 를 PK 로 사용. 공개 페이지에서 findUnique({where:{slug}}) 로 조회
//  - content 는 마크다운 유사 plain text (## 제목, - 리스트 지원)
//  - admin 은 textarea 로 자유 편집 가능
//  - DB 에 row 가 없으면 각 페이지 코드의 DEFAULT 문구 사용
// ─────────────────────────────────────────────────────────────
model SitePage {
  slug      String   @id
  title     String
  content   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─────────────────────────────────────────────────────────────
// 사이트 설정 (푸터, SEO 기본값 등 전역 설정을 key-value 로 저장)
//  - key = "footer" → 푸터 회사명/슬로건/고지 등 JSON
// ─────────────────────────────────────────────────────────────
model SiteSetting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
}

// ============================================================
// 인덱싱 로그 — 어떤 URL 이 어느 엔진에 언제 제출됐는지 기록
// ============================================================
model IndexingLog {
  id          String            @id @default(cuid())
  triggerType IndexingTrigger                     // 수동/크론/훅
  engine      IndexingEngine                      // 엔진 구분
  urlCount    Int                                 // 제출된 URL 수
  sampleUrls  String[]                            // 최대 10개만 저장 (디버깅용)
  status      IndexingStatus                      // success / partial / failed
  httpStatus  Int?                                // 외부 API 응답 코드
  errorMsg    String?           @db.Text          // 에러 메시지
  durationMs  Int                                 // 소요 시간 (ms)
  meta        Json?                               // 자유 필드
  createdAt   DateTime          @default(now())

  @@index([createdAt])
  @@index([engine, createdAt])
  @@index([triggerType, createdAt])
  @@map("indexing_log")
}

enum IndexingTrigger {
  MANUAL_ALL        // Admin UI: 전체 재푸시
  MANUAL_URL        // Admin UI: 단일 URL
  CRON_DAILY        // 매일 04:00 KST 크론
  PUBLISH_HOOK      // 정책 저장 직후 훅
}

enum IndexingEngine {
  INDEXNOW          // Bing + Yandex + Seznam + 기타
  GOOGLE_API        // Google Indexing API
  SITEMAP_PING      // Sitemap ping 방식 (Google, Bing)
  NAVER_MANUAL      // Naver 는 API 없음, 수기 클릭 기록용
  DAUM_MANUAL       // Daum 도 API 없음, 페이지등록/수기 클릭 기록용
}

// 색인 요청 큐 (Chrome 확장이 풀링해서 처리).
//
// 흐름:
//   1) 정책 publish 직후 / 어드민 수동 / 일배치 → 이 큐에 INSERT
//   2) Chrome 확장(background.js) 이 X-Indexing-Secret 헤더로
//      GET /api/indexing-queue/pull?engine=NAVER_MANUAL&limit=5
//      → PENDING 항목 가져가면서 status=IN_PROGRESS, requestedAt=now()
//   3) 확장이 Naver/Daum 색인 요청 페이지에 자동 입력 + 클릭
//   4) 결과를 POST /api/indexing-queue/result 로 회신
//      → status=SUCCESS|FAILED|CAPTCHA|RATE_LIMITED, completedAt=now()
//   5) IndexingLog 에도 1건 누적 기록 (대시보드 통계용)
//
// 일일 한도:
//   - NAVER_MANUAL: 50/일/사이트 (검색어드바이저)
//   - DAUM_MANUAL : 별도 한도 없으나 보수적으로 30/일 권장
model IndexingQueue {
  id           Int       @id @default(autoincrement())
  // VarChar(1024) — Postgres B-tree unique 인덱스 한도(8191B) 안전, 실제 정책 URL 은 200자 이내
  url          String    @db.VarChar(1024)
  engine       IndexingEngine                              // NAVER_MANUAL | DAUM_MANUAL | GOOGLE_API ...
  status       IndexingQueueStatus @default(PENDING)
  priority     Int       @default(0)                       // 높을수록 먼저
  attempts     Int       @default(0)
  lastError    String?   @db.Text
  requestedAt  DateTime?                                    // 확장이 가져간 시각
  completedAt  DateTime?                                    // 결과 회신 시각
  resultMeta   Json?                                        // 캡차 종류, HTTP status 등
  policyId     Int?                                         // 연관 정책(있으면)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([url, engine])
  @@index([engine, status, createdAt])
  @@index([status, createdAt])
  @@map("indexing_queue")
}

enum IndexingQueueStatus {
  PENDING        // 대기
  IN_PROGRESS    // 확장이 가져감(타임아웃 시 PENDING 으로 복구 가능)
  SUCCESS        // 색인 요청 완료
  FAILED         // 실패 (재시도 대상)
  CAPTCHA        // 캡차 만나서 일시정지
  RATE_LIMITED   // 일일 한도 도달
  SKIPPED        // 사용자가 건너뛰기
}

enum IndexingStatus {
  SUCCESS
  PARTIAL
  FAILED
}
